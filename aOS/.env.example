# aOS Environment Configuration
# Copy this to .env and fill in your values

# Redis
REDIS_URL=redis://localhost:6379

# MQTT
MQTT_BROKER=mqtt://localhost:1883

# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MODEL=gpt-4o

# Mem0
MEM0_API_KEY=your-mem0-api-key
MEM0_ORG_ID=your-org-id

# Exo
EXO_API_URL=http://localhost:8080

# Node Configuration (example for desktop)
AOS_NODE_NODE_ID=desktop-0
AOS_NODE_ROLE=desktop
AOS_NODE_IP=192.168.1.100
AOS_NODE_TAILSCALE_IP=100.x.x.x
AOS_NODE_VRAM_GB=24
AOS_NODE_RAM_GB=64
AOS_NODE_GPU_NAME=RTX 4090

# Directories
DATA_DIR=./data
CACHE_DIR=./cache
MODELS_DIR=./models
LORA_DIR=./lora_adapters
LOGS_DIR=./logs

# Debug
DEBUG=false
LOG_LEVEL=INFO
